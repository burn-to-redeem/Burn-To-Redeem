# Client-exposed variables (safe to expose)
VITE_BASE_CHAIN_ID=8453
VITE_TOKEN_GATE_CONTRACT=0x0000000000000000000000000000000000000000
VITE_REWARD_ERC1155_CONTRACT=0x0000000000000000000000000000000000000000

# Server-only variables (never expose in frontend)
BASE_RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# Token gate config
TOKEN_GATE_CONTRACT=0x0000000000000000000000000000000000000000
TOKEN_GATE_STANDARD=erc721
TOKEN_GATE_TOKEN_ID=0
TOKEN_GATE_TOKEN_IDS=

# Claim security
CLAIM_SIGNING_SECRET=replace-with-a-long-random-secret
GATE_MESSAGE_TTL_SECONDS=300
CLAIM_MESSAGE_TTL_SECONDS=300
GATE_PASS_TTL_SECONDS=900

# Treasury and reward config
TREASURY_PRIVATE_KEY=replace-with-treasury-private-key
TREASURY_WALLET_ADDRESS=0x0672700f90ce2aa72c68268219385e7e0c4a6418
REWARD_ERC1155_CONTRACT=0x0000000000000000000000000000000000000000
REWARD_ERC1155_TOKEN_IDS=1,2,3
REWARD_NFTS_PER_CLAIM=20

# Gas tuning for treasury transfer
REWARD_GAS_MODE=lowest
REWARD_MIN_PRIORITY_GWEI=0.000001
REWARD_BASE_FEE_MULTIPLIER_BPS=10000
REWARD_GAS_PRICE_MULTIPLIER_BPS=10000
REWARD_GAS_LIMIT=
REWARD_GAS_LIMIT_MULTIPLIER_BPS=12000
REWARD_TX_RETRY_ATTEMPTS=3
REWARD_TX_RETRY_WAIT_MS=30000
REWARD_RETRY_FEE_BUMP_BPS=12500
REWARD_ESTIMATE_FROM=

# Admin backend login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_SESSION_SECRET=replace-with-long-random-secret
ADMIN_SESSION_TTL_SECONDS=86400
RUNTIME_CONFIG_INTERNAL_SECRET=replace-with-long-random-secret
