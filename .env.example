# Client-exposed variables (safe to expose)
VITE_BASE_CHAIN_ID=8453
VITE_TOKEN_GATE_CONTRACT=0x0000000000000000000000000000000000000000
VITE_REWARD_ERC1155_CONTRACT=0x0000000000000000000000000000000000000000
VITE_BURN_COLLECTION_SLUG=cc0-by-pierre

# Server-only variables (never expose in frontend)
BASE_RPC_URL=https://mainnet.base.org
BASE_RPC_FALLBACK_URLS=
RPC_LOG_RETRY_ATTEMPTS=4
RPC_LOG_RETRY_DELAY_MS=350
CHAIN_ID=8453
BURN_COLLECTION_SLUG=cc0-by-pierre

# Token gate config
TOKEN_GATE_CONTRACT=0x0000000000000000000000000000000000000000
TOKEN_GATE_STANDARD=erc721
TOKEN_GATE_TOKEN_ID=0
TOKEN_GATE_TOKEN_IDS=

# Claim security
CLAIM_SIGNING_SECRET=replace-with-a-long-random-secret
GATE_MESSAGE_TTL_SECONDS=300
CLAIM_MESSAGE_TTL_SECONDS=300
GATE_PASS_TTL_SECONDS=900

# Persistent progression state (leaderboard + unlocked rewards)
PROGRESSION_STATE_BACKEND=blob
# For Postgres-backed progression set:
# PROGRESSION_STATE_BACKEND=postgres
# PROGRESSION_POSTGRES_URL=postgres://...
PROGRESSION_POSTGRES_URL=
PROGRESSION_POSTGRES_POOL_MAX=5
PROGRESSION_BLOB_STATE_PATH=state/progression-v1.json
# Vercel Blob token (recommended shared env name)
BLOB_READ_WRITE_TOKEN=
# Optional token override only for progression state
PROGRESSION_BLOB_RW_TOKEN=
# Optional shared secret for manual indexer calls; Vercel cron requests are auto-trusted.
PROGRESSION_INDEXER_SECRET=
# Max wallets scanned per indexer run.
PROGRESSION_INDEXER_MAX_WALLETS=40

# Persistent runtime overrides from Admin > Runtime tab
# Leave empty to auto-enable Blob when BLOB_READ_WRITE_TOKEN exists.
RUNTIME_CONFIG_BACKEND=blob
RUNTIME_CONFIG_BLOB_PATH=state/runtime-overrides-v1.json
# Optional token override only for runtime config overrides
RUNTIME_CONFIG_BLOB_RW_TOKEN=

# Treasury and reward config
TREASURY_PRIVATE_KEY=replace-with-treasury-private-key
TREASURY_WALLET_ADDRESS=0x0672700f90ce2aa72c68268219385e7e0c4a6418
TIP_RECEIVER_ADDRESS=0x0672700f90ce2aa72c68268219385e7e0c4a6418
TIP_POINTS_PER_ETH=20000
TIP_MIN_WEI=1000000000000000
REWARD_ERC1155_CONTRACT=0x0000000000000000000000000000000000000000
REWARD_COLLECTION_SLUG=cc0-by-pierre
REWARD_ERC1155_TOKEN_IDS=1,2,3
REWARD_NFTS_PER_CLAIM=20
REWARD_RANDOM_STRATEGY=token_uniform
CLAIMS_PER_GATE_TOKEN=1
REWARD_CLAIM_START_BLOCK=
REWARD_LOG_SCAN_STEP=9000
REWARD_TOKEN_DISCOVERY_START_BLOCK=
REWARD_TOKEN_DISCOVERY_LOG_SCAN_STEP=9000
REWARD_TOKEN_DISCOVERY_MAX_ITEMS=20000
OPENSEA_API_KEY=replace-with-opensea-api-key
OPENSEA_MCP_TOKEN=
OPENSEA_HTTP_RETRY_ATTEMPTS=3
OPENSEA_HTTP_RETRY_DELAY_MS=450
NFTS_TO_BURN_CACHE_TTL_SECONDS=90
NFTS_TO_BURN_CACHE_STALE_SECONDS=1800

# Gas tuning for treasury transfer
REWARD_GAS_MODE=lowest
REWARD_MIN_PRIORITY_GWEI=0.000001
REWARD_BASE_FEE_MULTIPLIER_BPS=10000
REWARD_GAS_PRICE_MULTIPLIER_BPS=10000
REWARD_GAS_LIMIT=
REWARD_GAS_LIMIT_MULTIPLIER_BPS=12000
REWARD_TX_RETRY_ATTEMPTS=3
REWARD_TX_RETRY_WAIT_MS=30000
REWARD_RETRY_FEE_BUMP_BPS=12500
REWARD_ESTIMATE_FROM=

# Optional burn router + mutable reward mint flow
BURN_ROUTER_CONTRACT=
BURN_ALLOWED_COLLECTIONS=
REWARD_MUTABLE_NFT_CONTRACT=
REWARD_MINT_ENABLED=1
REWARD_AUTO_MINT_ON_BURN=0
REWARD_UNLOCK_CLAIM_MAX_BATCH=20

# Burn unlock rewards (configure up to 5 CID prizes)
BURN_REWARD_CID_1=
BURN_REWARD_CID_2=
BURN_REWARD_CID_3=
BURN_REWARD_CID_4=
BURN_REWARD_CID_5=

# Website copy (editable in Admin > Website Tab)
WEBSITE_BRAND_NAME=Burn to Redeem
WEBSITE_ACCESS_TITLE=Burn to Redeem Access
WEBSITE_ACCESS_SUBTITLE=Sign once for token-gate access. Claim rewards later from the Redeemable Rewards tab inside the website.
WEBSITE_STEP1_TITLE=Step 1: Token-Gated Signature
WEBSITE_STEP1_SUBTITLE=Connect on Base and sign to prove ownership of the gate NFT.
